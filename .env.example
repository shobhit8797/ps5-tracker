# Copy this file to ".env" and fill in your values.
#
# --- Telegram ---------------------------------------------------------------
# 1. Open Telegram, talk to @BotFather, send /newbot, follow prompts.
#    BotFather replies with a token like 123456789:AAH...  -> paste below.
# 2. Get your chat id: message your new bot once, then open
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates in a browser and read
#    "chat":{"id": <number>}.  For a group, add the bot to the group first.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
